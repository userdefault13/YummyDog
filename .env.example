# Stripe (get keys from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# MongoDB (local or Atlas connection string)
# Use an explicit database name — Atlas URIs without a path default to "test"
MONGODB_URI=mongodb://127.0.0.1:27017/yummydog
# MONGODB_DB_NAME=yummydog

# Product import (Inventory) — Cloudflare AI worker
PRODUCT_AI_WORKER_URL=https://cloudflare-ai-worker.user-defaults.workers.dev
# PRODUCT_AI_WORKER_TOKEN=   # if WORKER_TOKEN secret is set on the worker

# Equipment Amazon import — ollama-amazon-parser (optional, local)
# Run: cd ~/Dev/ollama-amazon-parser && npm run dev
OLLAMA_PARSER_URL=http://localhost:3001